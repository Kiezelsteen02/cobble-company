rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any signed-in user can read player profiles (needed for username
    // uniqueness check), but each player can only write their own document.
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
                    && request.auth.uid == userId;
    }

    match /users/{userId}/transactions/{txId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Any authenticated player can read listings and post new ones.
    // Both sellers (cancel) and buyers (purchase) need to delete listings.
    match /market/{docId} {
      allow read, create, delete: if request.auth != null;
    }

    // Buyers create pending-payment documents; only the intended seller
    // can read or delete them.
    match /pendingPayments/{docId} {
      allow create:        if request.auth != null;
      allow read, delete:  if request.auth != null
                           && request.auth.uid == resource.data.sellerUID;
    }

    // Shared NPC market prices for guaranteed sell offers.
    // Everyone signed in sees the same prices and can trigger updates.
    match /npc_market/{itemId} {
      allow read, write: if request.auth != null
                         && (itemId == "wood" || itemId == "stone" || itemId == "planks");
    }

    // NPC price history log (last 24h shown in client UI).
    match /npc_market_history/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
